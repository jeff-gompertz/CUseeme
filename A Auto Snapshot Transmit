<style>
#csm-tx {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: #000;
  overflow: hidden;
  z-index: 9999;
  font-family: "VT323", ui-monospace, monospace;
}
#csm-tx canvas {
  position: absolute;
  top: 0; left: 0;
  display: block;
}
#csm-tx-status {
  position: absolute;
  top: 12px; right: 14px;
  z-index: 600;
  text-align: right;
  pointer-events: none;
}
#csm-tx-status .tx-label {
  font-size: 11px;
  color: rgba(0,255,200,0.4);
  letter-spacing: 3px;
  margin-bottom: 4px;
}
#csm-tx-status .tx-count {
  font-size: 28px;
  color: rgba(0,255,200,0.7);
  line-height: 1;
}
#csm-tx-status .tx-last {
  font-size: 11px;
  color: rgba(0,255,200,0.3);
  letter-spacing: 1px;
  margin-top: 3px;
}
#csm-tx-status .tx-dot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #00ffcc;
  margin-right: 5px;
  opacity: 0;
  transition: opacity 0.1s;
  vertical-align: middle;
}
#csm-tx-status .tx-dot.active { opacity: 1; }
#csm-tx-rlog {
  position: absolute;
  top: 0; right: 0;
  width: 42%; height: 100%;
  z-index: 400;
  pointer-events: none;
  overflow: hidden;
  padding: 80px 10px 10px 6px;
  display: flex;
  flex-direction: column;
}
.csm-tx-rline {
  font-size: 12px;
  line-height: 1.28;
  color: rgba(200,220,255,0.5);
  white-space: nowrap;
  overflow: hidden;
  flex-shrink: 0;
  animation: txrf .25s ease;
}
.csm-tx-rline.tx-sent { color: rgba(0,255,200,0.8); }
.csm-tx-rline.tx-err  { color: rgba(255,60,60,0.8); }
@keyframes txrf { from{opacity:0} to{opacity:1} }
#csm-tx-llog {
  position: absolute;
  left: 14px; bottom: 14px;
  z-index: 600;
  max-height: 18vh;
  overflow: hidden;
  display: flex;
  flex-direction: column-reverse;
  pointer-events: none;
}
.csm-tx-lline {
  font-size: 17px;
  line-height: 1.4;
  color: #ff3a2f;
  white-space: nowrap;
  animation: txlf .5s ease;
}
.csm-tx-lline.sent { color: #00ffcc; }
.csm-tx-lline.err  { color: #ff6060; }
@keyframes txlf { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }
.csm-tx-win {
  position: absolute;
  width: min(52vw, 270px);
  aspect-ratio: 9/13;
  background: rgba(220,235,255,0.07);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 16px;
  backdrop-filter: blur(18px) saturate(1.4);
  -webkit-backdrop-filter: blur(18px) saturate(1.4);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
  overflow: hidden;
  z-index: 500;
  cursor: grab;
}
.csm-tx-win.dragging { cursor: grabbing; z-index: 600; }
.csm-tx-win-bar {
  height: 22px; padding: 0 10px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(255,255,255,0.05);
  font-size: 11px; color: rgba(180,210,255,0.5);
  user-select: none;
}
.csm-tx-win-inner {
  position: relative; width: 100%; height: calc(100% - 22px);
}
.csm-tx-win-inner video {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  mix-blend-mode: screen;
}
</style>

<div id="csm-tx">
  <canvas id="csm-tx-gc"></canvas>
  <div id="csm-tx-status">
    <div class="tx-label">TRANSMITTING</div>
    <div class="tx-count"><span class="tx-dot" id="csm-tx-dot"></span><span id="csm-tx-count">0</span></div>
    <div class="tx-last" id="csm-tx-last">standing by</div>
  </div>
  <div id="csm-tx-rlog"></div>
  <div id="csm-tx-llog"></div>
</div>

<script>
(function(){

var WP_ENDPOINT   = 'https://art.jeffgompertz.site/wp-json/cuseeme/v1/snapshot';
var WP_SECRET     = 'csm-jeff-2024-xk9p';
var CAPTURE_MS    = 8000;

var wrap  = document.getElementById('csm-tx');
var gc    = document.getElementById('csm-tx-gc');
var gCtx  = gc.getContext('2d', { alpha: true });
var DPR   = Math.max(1, window.devicePixelRatio || 1);
var W, H;

function resize() {
  DPR = Math.max(1, window.devicePixelRatio || 1);
  W = window.innerWidth; H = window.innerHeight;
  gc.width  = Math.floor(W * DPR);
  gc.height = Math.floor(H * DPR);
  gc.style.width  = W + 'px';
  gc.style.height = H + 'px';
  gCtx.setTransform(DPR,0,0,DPR,0,0);
}
resize();
window.addEventListener('resize', resize);

var vc = document.createElement('canvas'), vCtx = vc.getContext('2d');
var pc = document.createElement('canvas'), pCtx = pc.getContext('2d');
function updRes() {
  vc.width = pc.width = 128;
  vc.height = pc.height = Math.max(8, Math.round(128 * H / W));
}
updRes();

function cl(v,a,b){ return Math.max(a,Math.min(b,v)); }

function procFrame() {
  var w = vc.width, h = vc.height;
  vCtx.fillStyle = '#000'; vCtx.fillRect(0,0,w,h);
  var g = vCtx.createLinearGradient(0,0,w,h);
  var tt = performance.now() * 0.0004;
  g.addColorStop(0, 'hsl('+((tt*360)%360)+',80%,40%)');
  g.addColorStop(1, 'hsl('+((tt*360+120)%360)+',80%,20%)');
  vCtx.fillStyle = g; vCtx.fillRect(0,0,w,h);
  var raw;
  try { raw = vCtx.getImageData(0,0,w,h); } catch(e){ return; }
  var sp = 6, d = raw.data, out = new Uint8ClampedArray(d.length);
  for (var y=0; y<h; y++) {
    var row = y*w;
    for (var x=0; x<w; x++) {
      var i=(row+x)*4, ir=(row+cl(x+sp,0,w-1))*4, ib=(row+cl(x-sp,0,w-1))*4;
      out[i]=d[ir]; out[i+1]=d[i+1]; out[i+2]=d[ib+2]; out[i+3]=255;
    }
  }
  pCtx.putImageData(new ImageData(out,w,h),0,0);
}

var wins = [], winCount = 0;
function getStream(){ try{ return gc.captureStream?gc.captureStream(30):null; }catch(e){ return null; } }

function makeWin(x,y) {
  winCount++;
  var el = document.createElement('div');
  el.className = 'csm-tx-win';
  el.style.left = x+'px'; el.style.top = y+'px';
  el.innerHTML =
    '<div class="csm-tx-win-bar"><span>window_'+String(winCount).padStart(4,'0')+'</span></div>'+
    '<div class="csm-tx-win-inner"><video autoplay muted playsinline></video></div>';
  wrap.appendChild(el);
  var v = el.querySelector('video');
  v.srcObject = getStream(); v.play().catch(function(){});
  var ang = Math.random()*Math.PI*2, sp = 18+Math.random()*30;
  var data = { el:el, vx:Math.cos(ang)*sp, vy:Math.sin(ang)*sp, drag:false };
  wins.push(data);
  var bar = el.querySelector('.csm-tx-win-bar');
  var sx=0,sy=0,sl=0,st=0;
  function onS(e){ data.drag=true; el.classList.add('dragging'); var r=el.getBoundingClientRect(); sl=r.left; st=r.top; sx=e.touches?e.touches[0].clientX:e.clientX; sy=e.touches?e.touches[0].clientY:e.clientY; document.addEventListener('pointermove',onM); document.addEventListener('pointerup',onE); document.addEventListener('touchmove',onM,{passive:false}); document.addEventListener('touchend',onE); if(e.preventDefault)e.preventDefault(); }
  function onM(e){ if(!data.drag)return; var cx=e.touches?e.touches[0].clientX:e.clientX,cy=e.touches?e.touches[0].clientY:e.clientY; el.style.left=(sl+(cx-sx))+'px'; el.style.top=(st+(cy-sy))+'px'; if(e.preventDefault)e.preventDefault(); }
  function onE(e){ data.drag=false; el.classList.remove('dragging'); var cx=e.changedTouches?e.changedTouches[0].clientX:e.clientX,cy=e.changedTouches?e.changedTouches[0].clientY:e.clientY; data.vx=(cx-sx)*1.8; data.vy=(cy-sy)*1.8; document.removeEventListener('pointermove',onM); document.removeEventListener('pointerup',onE); document.removeEventListener('touchmove',onM); document.removeEventListener('touchend',onE); }
  bar.addEventListener('pointerdown',onS);
  bar.addEventListener('touchstart',onS,{passive:false});
}

function doDrift(dt) {
  wins.forEach(function(d) {
    if(d.drag)return;
    var el=d.el, l=parseFloat(el.style.left), t=parseFloat(el.style.top);
    l+=d.vx*dt; t+=d.vy*dt;
    var rw=el.offsetWidth,rh=el.offsetHeight;
    if(l<0){l=0;d.vx=Math.abs(d.vx);} if(t<0){t=0;d.vy=Math.abs(d.vy);}
    if(l+rw>W){l=W-rw;d.vx=-Math.abs(d.vx);} if(t+rh>H){t=H-rh;d.vy=-Math.abs(d.vy);}
    d.vx+=(Math.random()-.5)*4*dt; d.vy+=(Math.random()-.5)*4*dt;
    d.vx=cl(d.vx,-60,60); d.vy=cl(d.vy,-60,60);
    el.style.left=l+'px'; el.style.top=t+'px';
  });
}

var scanX, lastT = performance.now();
scanX = W + 2;
function loop(now) {
  requestAnimationFrame(loop);
  var dt = Math.min(48,now-lastT)/1000; lastT=now;
  updRes(); procFrame();
  scanX -= 38*dt;
  if(scanX < -12) scanX = W+8;
  var norm=((scanX%W)+W)%W/W;
  var sx=Math.floor(norm*(pc.width-1));
  gCtx.save(); gCtx.imageSmoothingEnabled=false;
  try{ gCtx.drawImage(pc,sx,0,1,pc.height,Math.round(scanX),0,4,H); }catch(e){}
  gCtx.restore();
  doDrift(dt);
}
requestAnimationFrame(loop);

/* logging */
var pad2=function(n){return n<10?'0'+n:''+n;};
function ts(){var d=new Date();return pad2(d.getHours())+':'+pad2(d.getMinutes())+':'+pad2(d.getSeconds());}

var rlog=document.getElementById('csm-tx-rlog');
var rMsgs=['processedCanvas readback OK','scan stripe painted','vCanvas draw OK','RGB split applied','frame rendered','drift tick OK','window_stream active','getImageData OK','processedCanvas readback OK','processedCanvas readback OK'];
function rCap(){return Math.ceil(H/15.4)+2;}
function rFill(){rlog.innerHTML='';for(var i=0;i<rCap();i++)rAdd();}
function rAdd(msg,cls){
  var line=document.createElement('div');
  line.className='csm-tx-rline'+(cls?' '+cls:'');
  line.textContent=ts()+' \u2014 '+(msg||rMsgs[Math.floor(Math.random()*rMsgs.length)]);
  rlog.insertBefore(line,rlog.firstChild);
  while(rlog.children.length>rCap()+4)rlog.removeChild(rlog.lastChild);
}
rFill();
setInterval(function(){rAdd();},160);

var llog=document.getElementById('csm-tx-llog');
function lAdd(msg,cls){
  var d=document.createElement('div');
  d.className='csm-tx-lline'+(cls?' '+cls:'');
  d.textContent=msg;
  llog.insertBefore(d,llog.firstChild);
  while(llog.children.length>6)llog.removeChild(llog.lastChild);
}
['Demo loaded','scan raster injected','transmission standing by'].forEach(function(m,i){
  setTimeout(function(){lAdd(m);},300*i);
});
setInterval(function(){
  var msgs=['raster sweep active','RGB split: 6px','frame loop running','signal nominal','drift vector OK'];
  lAdd(msgs[Math.floor(Math.random()*msgs.length)]);
},2200);

/* capture + transmit */
var txCount=0;
var txCountEl=document.getElementById('csm-tx-count');
var txLastEl=document.getElementById('csm-tx-last');
var txDot=document.getElementById('csm-tx-dot');

function flashDot(){txDot.classList.add('active');setTimeout(function(){txDot.classList.remove('active');},400);}

function captureAndSend() {
  var dataURL;
  try { dataURL = gc.toDataURL('image/png'); }
  catch(e){ lAdd('capture failed: '+e.message,'err'); return; }

  txCount++;
  var label = 'cuseeme-frame-'+String(txCount).padStart(4,'0');
  lAdd('transmitting frame '+txCount+'...');
  rAdd('POST snapshot — frame '+txCount,'tx-sent');
  flashDot();

  

  fetch(WP_ENDPOINT, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      
    },
    body: JSON.stringify({ image: dataURL, label: label, secret: WP_SECRET }),
  })
  .then(function(res){ return res.json(); })
  .then(function(data){
    if(data.success){
      txCountEl.textContent = txCount;
      txLastEl.textContent  = data.filename;
      lAdd('saved: '+data.filename,'sent');
      rAdd('200 OK \u2014 '+data.filename,'tx-sent');
    } else {
      lAdd('error: '+(data.message||JSON.stringify(data)),'err');
      rAdd('failed \u2014 '+(data.message||'unknown'),'tx-err');
    }
  })
  .catch(function(err){
    lAdd('tx failed: '+err.message,'err');
    rAdd('fetch error \u2014 '+err.message,'tx-err');
  });
}

setTimeout(function(){
  lAdd('first transmission in 3s...');
  setTimeout(function(){
    captureAndSend();
    setInterval(captureAndSend, CAPTURE_MS);
  },3000);
},1000);

setTimeout(function(){
  for(var i=0;i<5;i++){
    (function(idx){
      setTimeout(function(){
        makeWin(40+Math.random()*W*.42,60+Math.random()*H*.38);
      },idx*200);
    })(i);
  }
},500);

})();
</script>